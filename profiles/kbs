[:!Ca ["osascript -e 'tell app \\"Finder\\" to activate'"]]  ; Cmd+a -> Finder
\`\`\`

### Layers (held key activates a mode)
\`\`\`clojure
:main [
  {:des "Caps Lock layer"
   :rules [
     [:##caps_lock ["caps-mode" 1] nil {:afterup ["caps-mode" 0]}]
     [:j :left_arrow ["caps-mode" 1]]    ; caps+j -> left
