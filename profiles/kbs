[:a :b]  ; a -> b

;; With modifier
[:!Ca :b]  ; Cmd+a -> b

;; Shell command
[:a [:!Ca "open -a Safari"]]

;; Simlayer (simultaneous press)
:nav-mode {:key :d}
[:n :left_arrow]  ; d+n -> left

;; Condition (app-specific)
[:a :b [:app "Terminal"]]
\`\`\``,
