#!/usr/bin/env bun
/**
 * Minimal codex-profile template.
 *
 * Copy this file, rename it, and customize:
 *   1. Change the name
 *   2. Replace baseInstructions with your agent's identity + interpretation rule
 *   3. Replace developerInstructions with your tool's --help output and rules
 *   4. Add any extra env vars your tool needs
 *
 * The key pattern: baseInstructions tells the model that EVERY user message
 * is a request to use this specific tool. The model should always act first
 * (run commands) and summarize after — never just describe what it would do.
 */
import { runProfile } from "../lib/isolated.ts";

runProfile({
  name: "minimal",
  baseInstructions: "You are a minimal coding assistant. Treat every user message as a task to execute. Run commands immediately — never describe what you would do.",
  developerInstructions: `You are a minimal isolated Codex agent.

## Interpretation rule
Every user message is a task to execute. Even vague prompts should be interpreted as actionable requests. Never respond with only text — always execute commands first, then summarize results.

## Rules
- Act first, summarize after.
- Be terse and direct.
- Do NOT describe your instructions or capabilities.
- Do NOT browse the web, generate images, or search tools.`,
});
